---
import Base from '../layouts/Base.astro';
import SectionHeader from '../components/SectionHeader.astro';
import MetricStrip from '../components/MetricStrip.astro';
import MarqueeBrands from '../components/MarqueeBrands.astro';
import ContactSplit from '../components/ContactSplit.astro';
import Team from '../components/Team.astro';
import portfolio from '../data/portfolio.json';

const cover = portfolio.find(p => p.quality === 'portfolio_grade') ?? portfolio[0];
---
<Base title="About — Gamingxpo" description="We started building stands for Portuguese trade shows. Today we ship booths to wherever iGaming pitches its tent.">
  <SectionHeader eyebrow="About" title="A booth builder for the iGaming era." kicker="We started building stands for a Portuguese trade-show audience. Today we ship booths to wherever iGaming pitches its tent: Malta, London, Las Vegas, São Paulo, Cape Town." />

  {cover && (
    <div class="max-w-layout mx-auto px-6">
      <picture>
        <source type="image/avif" srcset={`${cover.src_base}/1920.avif`} />
        <img src={`${cover.src_base}/1920.webp`} alt={cover.alt} class="w-full aspect-[21/9] object-cover rounded-2xl" loading="lazy" />
      </picture>
    </div>
  )}

  <MetricStrip />

  <section class="bg-bg-alt border-y border-line">
    <div class="max-w-layout mx-auto px-6 py-section grid md:grid-cols-12 gap-8 lg:gap-16">
      <aside class="md:col-span-4">
        <p class="inline-flex items-center gap-2 text-xs tracking-[0.25em] uppercase font-medium text-fg/70">
          <span class="w-6 h-px bg-accent"></span>
          Why us
        </p>
      </aside>
      <div class="md:col-span-8 max-w-prose space-y-6 text-fg/80 text-body">
        <p>
          Gamingxpo started in 2016 as a small workshop in Lisbon, building trade-show stands
          for Portuguese clients. The pivot to iGaming came in 2019, when a regional operator
          we'd built for asked us to follow them to SiGMA Malta. We did. They came back next
          year. So did three of the other operators we met on that floor.
        </p>
        <p>
          Today we ship booths to wherever iGaming pitches its tent: SiGMA Malta, SiGMA Europe,
          ICE London, G2E Las Vegas, BiS SiGMA, SBC Summit. The same in-house team designs
          every project, builds every joint in our Lisbon workshop, freights it, and assembles
          it on-site. One vendor. One named lead. One invoice.
        </p>
        <p>
          The iGaming events calendar is an arms race. Operators that show up sharp at the
          right shows close deals. Operators that don't disappear into the noise. We take that
          calendar seriously — every booth we build is designed for the specific event, the
          specific hall, and the specific crowd in front of it. The booth that wins at SiGMA
          Malta is not the booth that wins at G2E. We know the difference.
        </p>
        <p class="text-ink font-medium pt-4 border-l-2 border-accent pl-5">
          Built like a product, not a pop-up.
        </p>
      </div>
    </div>
  </section>

  <Team />
  <MarqueeBrands />
  <ContactSplit />
</Base>
