---
const { size = 32, withWordmark = true, className = '' } = Astro.props;
---
<a href="/" class={`inline-flex items-center gap-2.5 group ${className}`} aria-label="Gamingxpo home">
  <svg
    width={size}
    height={size}
    viewBox="0 0 64 64"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    class="shrink-0 transition-transform duration-300 group-hover:rotate-[12deg]"
    aria-hidden="true"
  >
    <defs>
      <linearGradient id="gxFill" x1="0" y1="0" x2="64" y2="64" gradientUnits="userSpaceOnUse">
        <stop offset="0" stop-color="currentColor" />
        <stop offset="1" stop-color="currentColor" stop-opacity="0.85" />
      </linearGradient>
    </defs>
    {/* angled booth-cube monogram */}
    <path d="M14 8 L50 8 L56 14 L56 50 L50 56 L14 56 L8 50 L8 14 Z" fill="url(#gxFill)" />
    <path d="M32 18 L46 32 L32 46 L18 32 Z" fill="var(--bg)" opacity="0.85" />
    <circle cx="32" cy="32" r="3.5" fill="currentColor" />
  </svg>
  {withWordmark && (
    <span class="font-display font-semibold tracking-tight text-[1.15rem] leading-none">
      Gamingxpo<span class="text-accent">.</span>
    </span>
  )}
</a>
