---
const { items = [
  {
    quote: "We've worked with bigger agencies. None turned around a renders-to-floor build in 23 days the way Gamingxpo did for SiGMA Malta. The booth pulled twice the foot traffic we forecasted.",
    name: 'Maria Constantinou',
    role: 'Head of Brand · BetVision',
    event: 'SiGMA Malta 2025',
    photo: 'https://i.pravatar.cc/120?img=47',
  },
  {
    quote: "Three events in eighteen months. Same crew, same standard every time. The on-site team caught a freight delay and rebuilt the structural frame overnight. Nobody at G2E knew anything had gone wrong.",
    name: 'Diego Ferreira',
    role: 'Marketing Director · Lúcida Gaming',
    event: 'G2E Las Vegas 2024',
    photo: 'https://i.pravatar.cc/120?img=15',
  },
  {
    quote: "The LED wall, the slot demo pods, the bar. Every supplier on a booth is usually someone else's problem. With Gamingxpo it's one phone call and one invoice. That's what we pay for.",
    name: 'Sofia Engelman',
    role: 'CMO · WildRiver iGaming',
    event: 'ICE London 2025',
    photo: 'https://i.pravatar.cc/120?img=32',
  },
] } = Astro.props;
---
<section class="bg-bg">
  <div class="max-w-layout mx-auto px-6 py-section">
    <header class="max-w-prose mb-12">
      <p class="inline-flex items-center gap-2 text-xs tracking-[0.25em] uppercase font-medium text-fg/70">
        <span class="w-6 h-px bg-accent"></span>
        Trusted by
      </p>
      <h2 class="font-display text-display-lg mt-4 text-ink">Operators that ship at events.</h2>
      <p class="mt-5 text-body text-fg/70">
        Brands that came back. Some twice in a year. None for the conference room view.
        For the booth that closed deals on the floor.
      </p>
    </header>

    <div class="grid md:grid-cols-3 gap-6">
      {items.map((t: any) => (
        <article class="relative bg-bg-alt border border-line rounded-2xl p-7 hover:shadow-[0_12px_40px_-12px_rgba(20,17,13,0.15)] transition-shadow">
          <svg class="w-10 h-10 text-accent" viewBox="0 0 32 32" fill="currentColor" aria-hidden="true">
            <path d="M9 9h6v6c0 4-2 6-6 7v-3c2-1 3-2 3-4H9V9zm12 0h6v6c0 4-2 6-6 7v-3c2-1 3-2 3-4h-3V9z"/>
          </svg>
          <blockquote class="mt-4 text-fg/85 text-body leading-relaxed">
            {t.quote}
          </blockquote>
          <footer class="mt-6 flex items-center gap-3 pt-5 border-t border-line">
            <img src={t.photo} alt={t.name} class="w-12 h-12 rounded-full object-cover" loading="lazy" />
            <div>
              <div class="text-ink font-medium text-sm">{t.name}</div>
              <div class="text-muted text-xs">{t.role}</div>
              {t.event && <div class="text-accent-dim text-xs mt-0.5 font-medium">{t.event}</div>}
            </div>
          </footer>
        </article>
      ))}
    </div>
  </div>
</section>
