---
const { items = [
  {
    name: 'Tiago Mendes',
    role: 'Founder & Creative Director',
    bio: '12 years building stands across Europe. Before Gamingxpo, ran an event architecture studio that won three SiGMA design awards.',
    photo: 'https://i.pravatar.cc/600?img=68',
  },
  {
    name: 'Inês Cordeiro',
    role: 'Head of Production',
    bio: 'Runs the workshop. Carpenter by trade, certified rigger, has personally hung every truss on every Gamingxpo build for the past four years.',
    photo: 'https://i.pravatar.cc/600?img=44',
  },
  {
    name: 'Bruno Aguiar',
    role: 'On-Site Lead',
    bio: 'Speaks four languages. Built booths in 14 countries. The person you actually want on the show floor at 3am when something needs rebuilding.',
    photo: 'https://i.pravatar.cc/600?img=33',
  },
  {
    name: 'Carla Pinto',
    role: 'Account & Project Lead',
    bio: 'The single point of contact for every project. Eight years in iGaming event production. Knows every venue rulebook by heart.',
    photo: 'https://i.pravatar.cc/600?img=49',
  },
] } = Astro.props;
---
<section class="bg-bg-alt border-y border-line">
  <div class="max-w-layout mx-auto px-6 py-section">
    <header class="grid md:grid-cols-12 gap-8 mb-12">
      <div class="md:col-span-5">
        <p class="inline-flex items-center gap-2 text-xs tracking-[0.25em] uppercase font-medium text-fg/70">
          <span class="w-6 h-px bg-accent"></span>
          The crew
        </p>
        <h2 class="font-display text-display-lg mt-4 text-ink">Four people you'll actually meet.</h2>
      </div>
      <p class="md:col-span-6 md:col-start-7 text-body text-fg/70 max-w-prose">
        No army of junior account handlers. The people you see here are the people who design,
        build, and run every Gamingxpo booth. One project, one team — start to teardown.
      </p>
    </header>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6">
      {items.map((p: any) => (
        <article class="group relative overflow-hidden rounded-2xl bg-bg">
          <div class="aspect-square overflow-hidden">
            <img src={p.photo} alt={p.name} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
          </div>
          <div class="p-5">
            <div class="text-ink font-display text-lg leading-tight">{p.name}</div>
            <div class="text-accent text-xs tracking-wide uppercase font-medium mt-1">{p.role}</div>
            <p class="text-muted text-sm mt-3 leading-relaxed">{p.bio}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
