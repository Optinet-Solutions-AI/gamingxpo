---
import Logo from './Logo.astro';

const links = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'Services' },
  { href: '/portfolio', label: 'Portfolio' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
const current = Astro.url.pathname;
---
<nav class="sticky top-0 z-50 bg-bg/80 backdrop-blur-md border-b border-line">
  <div class="max-w-layout mx-auto flex items-center justify-between px-6 py-4">
    <Logo size={30} />
    <ul class="hidden md:flex gap-7 text-sm">
      {links.map(l => (
        <li>
          <a
            href={l.href}
            class={`relative py-1 transition-colors ${current === l.href ? 'text-ink font-medium' : 'text-fg/70 hover:text-ink'}`}
          >
            {l.label}
            {current === l.href && <span class="absolute -bottom-0.5 left-0 right-0 h-px bg-ink"></span>}
          </a>
        </li>
      ))}
    </ul>
    <a
      href="/contact"
      class="hidden md:inline-flex items-center gap-2 bg-ink text-bg font-medium px-4 py-2 rounded-full text-sm hover:bg-fg transition-colors"
    >
      Start a project →
    </a>
  </div>
</nav>
