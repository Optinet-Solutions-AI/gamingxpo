---
const { items = ['SiGMA','ICE London','G2E Las Vegas','BiS SiGMA','GAT Expo','iGaming Next','SBC Summit'] } = Astro.props;
---
<section class="overflow-hidden border-y border-line bg-bg">
  <div class="max-w-layout mx-auto px-6 pt-10 pb-2">
    <p class="text-muted text-xs tracking-[0.25em] uppercase">Events we've built for</p>
  </div>
  <div class="flex gap-16 py-8 whitespace-nowrap motion-safe:animate-[marquee_30s_linear_infinite]">
    {[...items, ...items].map((name: string) => (
      <span class="font-display text-2xl text-fg/60 hover:text-ink transition-colors inline-flex items-center gap-3">
        {name}
        <svg width="6" height="6" viewBox="0 0 6 6" fill="none"><circle cx="3" cy="3" r="3" fill="var(--accent)"/></svg>
      </span>
    ))}
  </div>
</section>

<style>
  @keyframes marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
</style>
