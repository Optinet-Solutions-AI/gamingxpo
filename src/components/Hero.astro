---
import portfolio from '../data/portfolio.json';
const grade = portfolio.filter(p => p.quality === 'portfolio_grade' && p.subject !== 'other');
const cover = grade.find(p => p.subject === 'booth_exterior') ?? grade[0];
const sideA = grade[1] ?? cover;
const sideB = grade[2] ?? sideA;
const sideC = grade[3] ?? sideA;

const {
  eyebrow = 'Booths & Stands · iGaming',
  headline = 'Stand out at every iGaming event in the world.',
  sub = 'We design, build, and ship booths for SiGMA, ICE, G2E, BiS — wherever your brand needs to win the room.',
  cta = { href: '/contact', label: 'Start your booth' },
  secondary = { href: '/portfolio', label: 'See portfolio' }
} = Astro.props;
---
<section class="relative overflow-hidden">
  {/* subtle decorative shapes — amber dot, ink square, coral bar */}
  <div class="hidden md:block absolute top-24 right-8 w-3 h-3 bg-accent rounded-full" aria-hidden="true"></div>
  <div class="hidden md:block absolute top-44 right-32 w-2.5 h-2.5 bg-ink rotate-45" aria-hidden="true"></div>
  <div class="hidden md:block absolute top-64 left-8 w-8 h-1.5 bg-coral" aria-hidden="true"></div>

  <div class="max-w-layout mx-auto px-6 pt-20 pb-section grid lg:grid-cols-12 gap-12 items-center">
    <div class="lg:col-span-6">
      <p class="text-accent text-xs tracking-[0.25em] uppercase font-medium">{eyebrow}</p>
      <h1 class="font-display text-display-xl mt-4 max-w-[14ch]">{headline}</h1>
      <p class="mt-6 max-w-prose text-fg/75 text-body">{sub}</p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href={cta.href} class="inline-flex items-center gap-2 bg-ink text-bg font-medium px-6 py-3 rounded-full hover:bg-fg transition-colors">
          {cta.label}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10m0 0L9 4m4 4l-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </a>
        <a href={secondary.href} class="inline-flex items-center gap-2 border border-ink/20 text-ink px-6 py-3 rounded-full hover:border-ink transition-colors">
          {secondary.label}
        </a>
      </div>
      <div class="mt-10 flex items-center gap-6 text-xs text-muted">
        <div class="flex -space-x-2">
          {grade.slice(0,3).map(p => (
            <img src={`${p.src_base}/640.webp`} alt="" class="w-8 h-8 rounded-full border-2 border-bg object-cover" loading="lazy" />
          ))}
        </div>
        <span>200+ booths shipped across 14 countries</span>
      </div>
    </div>

    <div class="lg:col-span-6 grid grid-cols-6 grid-rows-6 gap-3 h-[520px] lg:h-[640px]">
      {cover && (
        <picture class="col-span-4 row-span-4 rounded-2xl overflow-hidden bg-line">
          <source type="image/avif" srcset={`${cover.src_base}/1440.avif`} />
          <img src={`${cover.src_base}/1440.webp`} alt={cover.alt} class="w-full h-full object-cover motion-safe:animate-[kenburns_24s_ease-out_infinite_alternate]" />
        </picture>
      )}
      {sideA && (
        <picture class="col-span-2 row-span-3 col-start-5 rounded-2xl overflow-hidden bg-line">
          <source type="image/avif" srcset={`${sideA.src_base}/640.avif`} />
          <img src={`${sideA.src_base}/640.webp`} alt={sideA.alt} class="w-full h-full object-cover" loading="lazy" />
        </picture>
      )}
      {sideB && (
        <picture class="col-span-2 row-span-3 col-start-5 row-start-4 rounded-2xl overflow-hidden bg-line">
          <source type="image/avif" srcset={`${sideB.src_base}/640.avif`} />
          <img src={`${sideB.src_base}/640.webp`} alt={sideB.alt} class="w-full h-full object-cover" loading="lazy" />
        </picture>
      )}
      {sideC && (
        <picture class="col-span-4 row-span-2 row-start-5 rounded-2xl overflow-hidden bg-line">
          <source type="image/avif" srcset={`${sideC.src_base}/960.avif`} />
          <img src={`${sideC.src_base}/960.webp`} alt={sideC.alt} class="w-full h-full object-cover" loading="lazy" />
        </picture>
      )}
    </div>
  </div>
</section>

<style>
  @keyframes kenburns {
    from { transform: scale(1.0); }
    to   { transform: scale(1.08) translate(-1%, -1%); }
  }
</style>
